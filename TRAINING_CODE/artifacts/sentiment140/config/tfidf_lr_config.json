    "min_df": 2,
    "max_df": 0.95,
    "sublinear_tf": true,
    "max_iter": 200,
    "solver": "saga",
    "class_weight": "balanced"
  },
  "figures": {
    "confusion_matrix": "e:\\桌面\\Graduation_Thesis\\Code\\artifacts\\sentiment140\\figures\\tfidf_lr_confusion_matrix.png"
